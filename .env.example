# ---------------------------------------------------------------
# Copiez ce fichier en .env et ajustez les valeurs.
# Le fichier .env ne doit jamais être commité (voir .gitignore).
# Vous pouvez aussi utiliser ./scripts/init.sh pour la configuration initiale.
# ---------------------------------------------------------------

# === Application ===
# Port d'écoute HTTP de l'application
APP_PORT=8080

# URL publique de l'application (utilisée dans les liens email)
APP_BASE_URL=http://localhost:8080

# Niveau de logs
# Exemples : "info", "debug", "info,garantify=debug"
RUST_LOG=info

# === Base de données ===
# Ces variables configurent à la fois PostgreSQL et l'application.
POSTGRES_USER=garantify
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=garantify

# DATABASE_URL est construit depuis les variables ci-dessus.
# Avec Docker Compose, "db" désigne le service PostgreSQL.
DATABASE_URL=postgres://garantify:changeme_in_production@db:5432/garantify

# === Sécurité ===
# Clé secrète pour les sessions (min. 64 caractères)
# Générer avec : openssl rand -hex 64
SESSION_SECRET=

# Clé de chiffrement AES-256 pour le webhook Slack (OBLIGATOIRE)
# Générer avec : openssl rand -base64 32
ENCRYPTION_KEY=

# === Email SMTP ===
# Adresse email expéditrice des alertes
MAIL_FROM=noreply@example.com

# Serveur SMTP — exemples :
#   OVH        : ssl0.ovh.net      port 465 (SSL) ou 587 (STARTTLS)
#   Gmail      : smtp.gmail.com    port 587 (STARTTLS)
#   Mailgun    : smtp.mailgun.org  port 587
#   Mailtrap   : sandbox.smtp.mailtrap.io port 587 (tests)
SMTP_HOST=smtp.example.com
# Port 465 = SSL implicite | Port 587 = STARTTLS
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=

# === Uploads ===
# Répertoire de stockage des fichiers uploadés (photos, factures)
UPLOAD_DIR=/data/uploads

# Taille maximale des uploads en mégaoctets
MAX_UPLOAD_MB=10
